{
  "name": "@psmmcp/cli",
  "version": "0.1.0",
  "description": "CLI tool — the psmmcp command for managing MCP servers, secrets, identities, and policies",
  "license": "MIT",
  "type": "module",
  "bin": {
    "psmmcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@psmmcp/types": "workspace:*",
    "@psmmcp/core": "workspace:*",
    "@psmmcp/mcp": "workspace:*",
    "@psmmcp/stdio-proxy": "workspace:*",
    "@psmmcp/gateway": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

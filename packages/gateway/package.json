{
  "name": "@psmmcp/gateway",
  "version": "0.1.0",
  "description": "HTTPS gateway — MCP lifecycle manager, Control Plane API, Streamable HTTP transport",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@psmmcp/types": "workspace:*",
    "@psmmcp/core": "workspace:*",
    "@psmmcp/mcp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fastify": "^5.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "cockatiel": "^3.0.0",
    "pino": "^9.0.0",
    "prom-client": "^15.0.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
